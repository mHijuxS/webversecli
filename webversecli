def cmd_config_login(args):
    email = args.email or input("Email: ").strip()
    password = args.password or getpass.getpass("Password: ")
    body = {"email": email, "password": password}
    try:
        data, resp = _req("/api/auth/login", "POST", body, raw=True, no_auth=True)
        parsed = json.loads(data)
    except SystemExit:
        return  # err() already printed

    token = parsed.get("token") or parsed.get("access_token") or parsed.get("jwt")
    if not token:
        # Token may only be returned via Set-Cookie (HttpOnly), not in JSON body.
        for cookie in resp.headers.get_all("Set-Cookie") or []:
            for part in cookie.split(";"):
                k, _, v = part.strip().partition("=")
                if k == "token" and v:
                    token = v
                    break
            if token:
                break
    if not token:
        err(f"Login succeeded but no token in response body or Set-Cookie: {parsed}")
        sys.exit(1)

    cfg = load_config()
    cfg["token"] = token
    save_config(cfg)
    ok(f"Logged in. Token saved.")

def cmd_config_logout(_args):
    _post("/api/auth/logout")
    cfg = load_config()
    cfg.pop("token", None)
    save_config(cfg)
    ok("Logged out and token cleared.")

def cmd_config_set_token(args):
