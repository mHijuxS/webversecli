    cl.add_argument("--category",   default="", help="Filter by category (e.g. sqli, xss, idor)")
    cl.add_argument("--difficulty", default="", help="Filter: easy/medium/hard/master")
    cl.add_argument("--search",     default="", help="Search name/description/category")
    cl.add_argument("--sort",       default="", choices=["", "released", "solves", "xp", "name"],
                    help="Sort results (released = most recent first; requires per-challenge detail fetch)")

    cs = chals_sub.add_parser("show",   help="Show challenge details"); cs.add_argument("slug")
    cstart = chals_sub.add_parser("start", help="Start a challenge");   cstart.add_argument("slug")
