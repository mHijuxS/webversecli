def cmd_challenges_list(args):
    data = _get("/api/challenges")
    filtered = []
    for ch in data:
        if args.free and not ch.get("is_free"):
            continue
        if args.difficulty and ch.get("difficulty", "").lower() != args.difficulty.lower():
            continue
        if args.category and ch.get("category", "").lower() != args.category.lower():
            continue
        if args.search and not (_match(ch.get("name",""), args.search) or
                                _match(ch.get("description",""), args.search) or
                                _match(ch.get("category",""), args.search)):
            continue
        filtered.append(ch)

    sort_mode = getattr(args, "sort", "") or ""
    if sort_mode == "released":
        # /api/challenges omits created_at; fetch detail per slug in parallel.
        import concurrent.futures as _cf
        def _fetch_created(ch):
            try:
                d = _get(f"/api/challenges/{ch['slug']}")
                ch["created_at"] = d.get("created_at", "")
            except SystemExit:
                ch["created_at"] = ""
            return ch
        with _cf.ThreadPoolExecutor(max_workers=10) as _ex:
            filtered = list(_ex.map(_fetch_created, filtered))
        filtered.sort(key=lambda c: c.get("created_at") or "", reverse=True)
    elif sort_mode == "solves":
        filtered.sort(key=lambda c: c.get("total_solves") or 0, reverse=True)
    elif sort_mode == "xp":
        filtered.sort(key=lambda c: c.get("xp_reward") or 0, reverse=True)
    elif sort_mode == "name":
        filtered.sort(key=lambda c: (c.get("name") or "").lower())

    headers = ["Slug", "Name", "Category", "Difficulty", "Access", "XP", "Solves"]
    if sort_mode == "released":
        headers.append("Released")
    rows = []
    for ch in filtered:
        row = [
            ch["slug"],
            ch["name"][:38],
            ch.get("category", ""),
            ch["difficulty"],
            _free_badge(ch.get("is_free", False)),
            str(ch.get("xp_reward", "")),
            str(ch.get("total_solves", "")),
        ]
        if sort_mode == "released":
            row.append((ch.get("created_at") or "")[:10])
        rows.append(row)
    if not rows:
        info("No challenges match the given filters.")
        return
    table(headers, rows)
    info(f"{len(rows)} challenge(s) shown.")

