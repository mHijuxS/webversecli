# ── Commands: mystery challenges (retired daily/weekly events archive) ─────────
# Served by /api/mystery-challenges (NOT /api/challenges or /api/events).
# The list endpoint omits per-user solve state; detail carries `user_completed`.

def _resolve_mystery(slug_or_id: str):
    data = _get("/api/mystery-challenges")
    for ev in data:
        if (str(ev.get("event_id")) == str(slug_or_id) or
                ev.get("slug") == slug_or_id or
                ev.get("package_slug") == slug_or_id):
            return ev["event_id"], ev.get("slug") or ev.get("package_slug")
    err(f"Mystery challenge not found: {slug_or_id}")
    sys.exit(1)

def cmd_mystery_list(args):
    data = _get("/api/mystery-challenges")
    filtered = []
    for ev in data:
        if args.kind and ev.get("kind", "").lower() != args.kind.lower():
            continue
        if args.difficulty and ev.get("difficulty", "").lower() != args.difficulty.lower():
            continue
        if args.category and ev.get("category", "").lower() != args.category.lower():
            continue
        if args.search and not (_match(ev.get("name", ""), args.search) or
                                _match(ev.get("description", ""), args.search) or
                                _match(ev.get("category", ""), args.search)):
            continue
        filtered.append(ev)

    # Solve-state lives only on the detail endpoint — fetch per slug in parallel.
    want_status = args.unsolved or args.solved or args.status
    if want_status:
        import concurrent.futures as _cf
        def _fetch_status(ev):
            try:
                d = _get(f"/api/mystery-challenges/{ev['slug']}")
                ev["user_completed"] = bool(d.get("user_completed"))
            except SystemExit:
                ev["user_completed"] = None
            return ev
        with _cf.ThreadPoolExecutor(max_workers=10) as _ex:
            filtered = list(_ex.map(_fetch_status, filtered))
        if args.unsolved:
            filtered = [e for e in filtered if e.get("user_completed") is False]
        elif args.solved:
            filtered = [e for e in filtered if e.get("user_completed") is True]

    sort_mode = getattr(args, "sort", "") or "released"
    if sort_mode == "solves":
        filtered.sort(key=lambda e: e.get("total_solves") or 0, reverse=True)
    elif sort_mode == "xp":
        filtered.sort(key=lambda e: e.get("xp_reward") or 0, reverse=True)
    elif sort_mode == "name":
        filtered.sort(key=lambda e: (e.get("name") or "").lower())
    else:  # released (default) — most recent first
        filtered.sort(key=lambda e: e.get("starts_at") or "", reverse=True)

    headers = ["Slug", "Name", "Kind", "Category", "Difficulty", "XP", "Solves"]
    if want_status:
        headers.append("Solved")
    rows = []
    for ev in filtered:
        row = [
            ev.get("slug") or ev.get("package_slug", ""),
            (ev.get("name") or ev.get("package_name", ""))[:30],
            ev.get("kind", ""),
            ev.get("category", ""),
            ev.get("difficulty", ""),
            str(ev.get("xp_reward", "")),
            str(ev.get("total_solves", "")),
        ]
        if want_status:
            uc = ev.get("user_completed")
            row.append(_c("32", "yes") if uc else (_c("90", "?") if uc is None else _c("33", "no")))
        rows.append(row)
    if not rows:
        info("No mystery challenges match the given filters.")
        return
    table(headers, rows)
    info(f"{len(rows)} mystery challenge(s) shown.")

