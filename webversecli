def cmd_labs_list(args):
    data = _get("/api/labs")
    foundational = _get("/api/foundational-labs")
    all_labs = list(data) + list(foundational)
    rows = []
    for lab in all_labs:
        is_free = lab.get("is_free") or lab.get("is_effectively_free", False)
        if args.free and not is_free:
            continue
        if args.difficulty and lab.get("difficulty", "").lower() != args.difficulty.lower():
            continue
        if args.tag and args.tag.lower() not in [t.lower() for t in lab.get("tags", [])]:
            continue
        if args.search and not (_match(lab.get("name",""), args.search) or
                                _match(lab.get("description",""), args.search) or
                                any(_match(t, args.search) for t in lab.get("tags", []))):
            continue
        rows.append([
            lab["slug"],
            lab["name"],
            lab["difficulty"],
            _free_badge(is_free),
            str(lab.get("total_solves", "")),
            ", ".join(lab.get("tags", [])[:3]),
        ])
    if not rows:
        info("No labs match the given filters.")
        return
    table(["Slug", "Name", "Difficulty", "Access", "Solves", "Tags"], rows)
    info(f"{len(rows)} lab(s) shown.")

