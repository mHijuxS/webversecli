    lab_d = _get("/api/labs/active").get("active_lab")
    if lab_d:
        slug = lab_d["lab_slug"]
        info(f"Submitting to active lab: {lab_d['lab_name']}")
        d = _post(f"/api/labs/{slug}/submit-flag", {"flag": flag})
        (ok if d.get("correct") else err)(f"{'Correct!' if d.get('correct') else 'Wrong flag.'} {d.get('message','')}")
        if not d.get("correct"): sys.exit(1)
        return

    ch_d = _get("/api/challenges/active").get("active_challenge")
    if ch_d:
        slug = ch_d["challenge_slug"]
        info(f"Submitting to active challenge: {ch_d['challenge_name']}")
        d = _post(f"/api/challenges/{slug}/submit-flag", {"flag": flag})
        (ok if d.get("correct") else err)(f"{'Correct!' if d.get('correct') else 'Wrong flag.'} {d.get('message','')}")
        if not d.get("correct"): sys.exit(1)
        return

    ev_d = _get("/api/events/active").get("active_event")
    if ev_d:
        event_id = ev_d.get("event_id")
        info(f"Submitting to active event: {ev_d.get('package_name') or ev_d.get('name')}")
        d = _post(f"/api/events/{event_id}/submit-flag", {"flag": flag})
        (ok if d.get("correct") else err)(f"{'Correct!' if d.get('correct') else 'Wrong flag.'} {d.get('message','')}")
        if not d.get("correct"): sys.exit(1)
        return

    err("No active lab, challenge, or event found. Start one first.")
    sys.exit(1)

