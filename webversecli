    ll.add_argument("--tag",        default="",          help="Filter by tag (e.g. sqli, ssrf)")
    ll.add_argument("--search",     default="",          help="Search name/description/tags")

    labs_sub.add_parser("filters", help="Show available tags, techs, difficulties")

    ls = labs_sub.add_parser("show",   help="Show lab details"); ls.add_argument("slug")
    lstart = labs_sub.add_parser("start", help="Start a lab");  lstart.add_argument("slug")
    labs_sub.add_parser("stop",   help="Stop active lab")
    labs_sub.add_parser("active", help="Show active lab")

    lsub = labs_sub.add_parser("submit", help="Submit a lab flag")
    lsub.add_argument("slug")
    lsub.add_argument("flag", nargs="?")

    lwr = labs_sub.add_parser("writeup", help="Download lab writeup PDF (must be solved)")
    lwr.add_argument("slug")
    lwr.add_argument("output", nargs="?", help="Output path (default: ~/SLUG-writeup.pdf)")

    # ── challenges ────────────────────────────────────────────────────────────
    chals = sub.add_parser("challenges", help="Challenge management")
    chals_sub = chals.add_subparsers(dest="chals_action")

    cl = chals_sub.add_parser("list", help="List challenges with optional filters")
