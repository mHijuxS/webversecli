def _resolve_event(slug_or_id: str):
    events = _get("/api/events")
    for ev in events:
        if (str(ev["event_id"]) == str(slug_or_id) or
                ev.get("slug") == slug_or_id or
                ev.get("package_slug") == slug_or_id):
            return ev["event_id"], ev.get("slug") or ev.get("package_slug")
    err(f"Event not found: {slug_or_id}")
    sys.exit(1)

