# ── Config ────────────────────────────────────────────────────────────────────

CONFIG_PATH = Path.home() / ".config" / "webversecli" / "config.json"
BASE_URL = "https://api.webverselabs-pro.com"
DASHBOARD = "https://dashboard.webverselabs-pro.com"

# ── Colours ───────────────────────────────────────────────────────────────────

def _c(code, text): return f"\033[{code}m{text}\033[0m"
def ok(msg):   print(_c("32", f"[+] {msg}"))
def err(msg):  print(_c("31", f"[-] {msg}"), file=sys.stderr)
def info(msg): print(_c("36", f"[*] {msg}"))
def warn(msg): print(_c("33", f"[!] {msg}"))

def table(headers, rows):
    if not rows:
        return
    widths = [max(len(str(r[i])) for r in ([headers] + rows)) for i in range(len(headers))]
    sep = "  "
    print(_c("1", sep.join(str(h).ljust(widths[i]) for i, h in enumerate(headers))))
    print(_c("90", sep.join("-" * w for w in widths)))
    for row in rows:
        print(sep.join(str(v).ljust(widths[i]) for i, v in enumerate(row)))

# ── Config management ─────────────────────────────────────────────────────────

def load_config() -> dict:
    if CONFIG_PATH.exists():
        return json.loads(CONFIG_PATH.read_text())
    return {}

def save_config(cfg: dict):
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(cfg, indent=2))

def get_token() -> str:
    token = os.environ.get("WEBVERSECLI_TOKEN") or load_config().get("token", "")
    if not token:
        err("No token set. Run: webversecli config login  OR  webversecli config set-token TOKEN")
        sys.exit(1)
    return token

# ── HTTP client ───────────────────────────────────────────────────────────────

def _req(path: str, method: str = "GET", body=None, raw: bool = False, no_auth: bool = False):
    hdrs = {
        "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:150.0) Gecko/20100101 Firefox/150.0",
        "Accept": "application/json",
        "Accept-Encoding": "gzip",
        "Referer": f"{DASHBOARD}/",
        "Origin": DASHBOARD,
        "Sec-Fetch-Dest": "empty",
        "Sec-Fetch-Mode": "cors",
        "Sec-Fetch-Site": "same-site",
    }
    if not no_auth:
        hdrs["Cookie"] = f"token={get_token()}"
    req = urllib.request.Request(BASE_URL + path, headers=hdrs, method=method)
    if body is not None:
        req.add_header("Content-Type", "application/json")
        req.data = json.dumps(body).encode()
    try:
        with urllib.request.urlopen(req, timeout=15) as r:
            data = r.read()
            if r.headers.get("Content-Encoding") == "gzip":
                data = gzip.decompress(data)
            if raw:
                return data, r
            return json.loads(data) if data else {}
    except urllib.error.HTTPError as e:
        data = e.read()
        try:
            if e.headers.get("Content-Encoding") == "gzip":
                data = gzip.decompress(data)
        except Exception:
            pass
        try:
            parsed = json.loads(data)
            detail = parsed.get("detail", str(parsed))
            if isinstance(detail, list):
                detail = "; ".join(str(x) for x in detail)
        except Exception:
            detail = data.decode(errors="replace")
        err(f"HTTP {e.code}: {detail}")
        sys.exit(1)
    except Exception as ex:
        err(f"Request failed: {ex}")
        sys.exit(1)

def _get(path): return _req(path)
def _post(path, body=None): return _req(path, "POST", body)
def _get_raw(path):
    data, _ = _req(path, raw=True)
    return data

# ── Helpers ───────────────────────────────────────────────────────────────────

def _read_flag(flag_arg):
    if flag_arg:
        return flag_arg.strip()
    if not sys.stdin.isatty():
        return sys.stdin.read().strip()
    return input("Flag: ").strip()

def _free_badge(is_free):
    return _c("32", "free") if is_free else _c("90", "pro")

def _fmt_time(ts):
    return ts.replace("T", " ").split(".")[0].split("+")[0] if ts else "N/A"

def _match(text, query):
    return not query or query.lower() in text.lower()

def _bar(done, total, width=20):
    if not total:
        return "[" + " " * width + "] 0%"
    pct = int(done / total * 100)
    filled = int(done / total * width)
    return f"[{'█' * filled}{'░' * (width - filled)}] {pct}%"

