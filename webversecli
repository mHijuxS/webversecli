    # ── mystery ───────────────────────────────────────────────────────────────
    mys = sub.add_parser("mystery", help="Mystery challenges (retired daily/weekly events archive)")
    mys_sub = mys.add_subparsers(dest="mys_action")
    ml = mys_sub.add_parser("list", help="List mystery challenges")
    ml.add_argument("--unsolved",   action="store_true", help="Only unsolved (fetches solve-state per challenge)")
    ml.add_argument("--solved",     action="store_true", help="Only solved")
    ml.add_argument("--status",     action="store_true", help="Show Solved column without filtering")
    ml.add_argument("--kind",       default="", help="Filter: daily/weekly")
    ml.add_argument("--category",   default="", help="Filter by category (e.g. sqli, jwt, idor)")
    ml.add_argument("--difficulty", default="", help="Filter: easy/medium/hard/master")
    ml.add_argument("--search",     default="", help="Search name/description/category")
    ml.add_argument("--sort",       default="", choices=["", "released", "solves", "xp", "name"],
                    help="Sort results (default: released, most recent first)")
    msh = mys_sub.add_parser("show", help="Show mystery challenge details"); msh.add_argument("slug")
    mstart = mys_sub.add_parser("start", help="Start a mystery challenge"); mstart.add_argument("slug")
    mys_sub.add_parser("stop",   help="Stop active mystery challenge")
    mys_sub.add_parser("active", help="Show active mystery/event instance")
    msub = mys_sub.add_parser("submit", help="Submit a mystery challenge flag")
    msub.add_argument("slug")
    msub.add_argument("flag", nargs="?")

    # ── ranges ────────────────────────────────────────────────────────────────
    rngs = sub.add_parser("ranges", help="Ranges (multi-flag environments)")
    rngs_sub = rngs.add_subparsers(dest="rngs_action")
    rngs_sub.add_parser("list",   help="List ranges")
    rsh = rngs_sub.add_parser("show",   help="Show range details"); rsh.add_argument("slug")
    rstart = rngs_sub.add_parser("start", help="Start a range");    rstart.add_argument("slug")
    rngs_sub.add_parser("stop",   help="Stop active range")
    rngs_sub.add_parser("active", help="Show active range")
    rsub = rngs_sub.add_parser("submit", help="Submit a range flag")
    rsub.add_argument("slug")
    rsub.add_argument("flag", nargs="?")

    # ── flag (smart) ──────────────────────────────────────────────────────────
    fl = sub.add_parser("flag", help="Smart flag submission (auto-detects active lab/challenge/event)")
    fl_sub = fl.add_subparsers(dest="fl_action")
    fls = fl_sub.add_parser("submit", help="Submit to whatever is currently active")
    fls.add_argument("flag", nargs="?")

    # ── learning-paths ────────────────────────────────────────────────────────
    lp = sub.add_parser("learning-paths", help="Learning paths")
    lp_sub = lp.add_subparsers(dest="lp_action")
    lp_sub.add_parser("list", help="List learning paths")
    lpsh = lp_sub.add_parser("show", help="Show path details and modules")
    lpsh.add_argument("slug")

    # ── leaderboard ───────────────────────────────────────────────────────────
    lb = sub.add_parser("leaderboard", help="Leaderboard")
    lb.add_argument("period", nargs="?", default="weekly",
                    choices=["weekly", "monthly", "all-time"])

    # ── tracks ────────────────────────────────────────────────────────────────
    trks = sub.add_parser("tracks", help="Skill tracks (curated challenge/lab collections)")
    trks_sub = trks.add_subparsers(dest="trks_action")

    tl = trks_sub.add_parser("list", help="List all tracks")
    tl.add_argument("--family",     default="", help="Filter by family (e.g. injection, foundations, cert-prep)")
    tl.add_argument("--difficulty", default="", help="Filter: easy/medium/hard/foundational")
    tl.add_argument("--enrolled",   action="store_true", help="Show only enrolled tracks")
    tl.add_argument("--search",     default="", help="Search name/description/family")

    tsh = trks_sub.add_parser("show", help="Show track details and item list")
    tsh.add_argument("slug")

    ten = trks_sub.add_parser("enroll", help="Enroll in a track")
    ten.add_argument("slug")

    tun = trks_sub.add_parser("unenroll", help="Unenroll from a track")
    tun.add_argument("slug")

    tlk = trks_sub.add_parser("like", help="Like a track")
    tlk.add_argument("slug")

    tulk = trks_sub.add_parser("unlike", help="Unlike a track")
    tulk.add_argument("slug")

    # ── vpn ───────────────────────────────────────────────────────────────────
    vpn = sub.add_parser("vpn", help="VPN management")
    vpn_sub = vpn.add_subparsers(dest="vpn_action")
    vpn_sub.add_parser("status", help="VPN connection status")
    vd = vpn_sub.add_parser("download", help="Download .ovpn config")
    vd.add_argument("output", nargs="?")

    return p

# ── Dispatch ──────────────────────────────────────────────────────────────────

def main():
    parser = build_parser()
    args = parser.parse_args()

    if args.cmd == "config":
        if   args.cfg_action == "login":     cmd_config_login(args)
        elif args.cfg_action == "logout":    cmd_config_logout(args)
        elif args.cfg_action == "set-token": cmd_config_set_token(args)
        elif args.cfg_action == "show":      cmd_config_show(args)
        else: parser.parse_args(["config", "--help"])

    elif args.cmd == "me":
        cmd_me(args)

    elif args.cmd == "labs":
        a = getattr(args, "labs_action", None)
        if   a == "list":    cmd_labs_list(args)
        elif a == "filters": cmd_labs_filters(args)
        elif a == "show":    cmd_labs_show(args)
        elif a == "start":   cmd_labs_start(args)
        elif a == "stop":    cmd_labs_stop(args)
        elif a == "active":  cmd_labs_active(args)
        elif a == "submit":  cmd_labs_submit(args)
        elif a == "writeup": cmd_labs_writeup(args)
        else: parser.parse_args(["labs", "--help"])

    elif args.cmd == "challenges":
        a = getattr(args, "chals_action", None)
        if   a == "list":   cmd_challenges_list(args)
        elif a == "show":   cmd_challenges_show(args)
        elif a == "start":  cmd_challenges_start(args)
        elif a == "stop":   cmd_challenges_stop(args)
        elif a == "active": cmd_challenges_active(args)
        elif a == "submit": cmd_challenges_submit(args)
        else: parser.parse_args(["challenges", "--help"])

    elif args.cmd == "events":
        a = getattr(args, "evs_action", None)
        if   a == "list":   cmd_events_list(args)
        elif a == "show":   cmd_events_show(args)
        elif a == "start":  cmd_events_start(args)
        elif a == "stop":   cmd_events_stop(args)
        elif a == "active": cmd_events_active(args)
        elif a == "submit": cmd_events_submit(args)
        else: parser.parse_args(["events", "--help"])

    elif args.cmd == "mystery":
        a = getattr(args, "mys_action", None)
        if   a == "list":   cmd_mystery_list(args)
        elif a == "show":   cmd_mystery_show(args)
        elif a == "start":  cmd_mystery_start(args)
        elif a == "stop":   cmd_mystery_stop(args)
        elif a == "active": cmd_mystery_active(args)
        elif a == "submit": cmd_mystery_submit(args)
        else: parser.parse_args(["mystery", "--help"])

    elif args.cmd == "ranges":
        a = getattr(args, "rngs_action", None)
        if   a == "list":   cmd_ranges_list(args)
        elif a == "show":   cmd_ranges_show(args)
        elif a == "start":  cmd_ranges_start(args)
        elif a == "stop":   cmd_ranges_stop(args)
        elif a == "active": cmd_ranges_active(args)
        elif a == "submit": cmd_ranges_submit(args)
        else: parser.parse_args(["ranges", "--help"])

    elif args.cmd == "flag":
        if getattr(args, "fl_action", None) == "submit":
            cmd_flag_submit(args)
        else:
            parser.parse_args(["flag", "--help"])

    elif args.cmd == "learning-paths":
        a = getattr(args, "lp_action", None)
        if   a == "list": cmd_paths_list(args)
        elif a == "show": cmd_paths_show(args)
        else: parser.parse_args(["learning-paths", "--help"])

    elif args.cmd == "leaderboard":
        cmd_leaderboard(args)

    elif args.cmd == "tracks":
        a = getattr(args, "trks_action", None)
        if   a == "list":     cmd_tracks_list(args)
        elif a == "show":     cmd_tracks_show(args)
        elif a == "enroll":   cmd_tracks_enroll(args)
        elif a == "unenroll": cmd_tracks_unenroll(args)
        elif a == "like":     cmd_tracks_like(args)
        elif a == "unlike":   cmd_tracks_unlike(args)
        else: parser.parse_args(["tracks", "--help"])

    elif args.cmd == "vpn":
        a = getattr(args, "vpn_action", None)
        if   a == "status":   cmd_vpn_status(args)
        elif a == "download": cmd_vpn_download(args)
        else: parser.parse_args(["vpn", "--help"])

    else:
        parser.print_help()


if __name__ == "__main__":
    main()
