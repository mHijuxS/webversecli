def build_parser():
    p = argparse.ArgumentParser(
        prog="webversecli",
        description="WebVerse Labs CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=r"""
Examples:
  webversecli config login                          # login with email+password
  webversecli config login --email you@mail.com    # skip prompt
  webversecli config set-token eyJ...              # set token directly
  webversecli config logout

  webversecli me                                   # profile
  webversecli me stats                             # XP, rank, streaks, breakdown
  webversecli me progress                          # completed labs/challenges
  webversecli me achievements                      # unlocked achievements

  webversecli labs list [--free] [--difficulty easy] [--tag sqli] [--search TEXT]
  webversecli labs filters                         # available tags/techs/difficulties
  webversecli labs show arcadenal
  webversecli labs start arcadenal
  webversecli labs active
  webversecli labs stop
  webversecli labs submit arcadenal WEBVERSE{flag}
  webversecli labs writeup arcadenal [~/out.pdf]  # download PDF writeup

  webversecli challenges list [--free] [--category sqli] [--difficulty easy] [--search TEXT]
  webversecli challenges show gatekeeper
  webversecli challenges start gatekeeper
  webversecli challenges stop
  webversecli challenges submit gatekeeper WEBVERSE{flag}

  webversecli events list
  webversecli events show the-caretaker
  webversecli events start the-caretaker
  webversecli events stop
  webversecli events submit the-caretaker WEBVERSE{flag}

  webversecli mystery list                          # retired daily/weekly archive
  webversecli mystery list --unsolved               # only ones you haven't solved
  webversecli mystery list --status --kind weekly   # weekly, with Solved column
  webversecli mystery show bear
  webversecli mystery start bear
  webversecli mystery submit bear WEBVERSE{flag}

  webversecli ranges list
  webversecli ranges show bedrock

  webversecli flag submit WEBVERSE{flag}           # auto-detect active
  wl-paste | wvf                                   # clipboard → smart submit

  webversecli learning-paths list
  webversecli learning-paths show junior-web-hacker

  webversecli leaderboard [weekly|monthly|all-time]

  webversecli tracks list                           # list all tracks
  webversecli tracks list --enrolled               # only enrolled
  webversecli tracks list --family injection       # filter by family
  webversecli tracks show sqli-mastery             # detail + item list
  webversecli tracks enroll sqli-mastery           # enroll in track
  webversecli tracks unenroll sqli-mastery         # unenroll
  webversecli tracks like sqli-mastery             # like a track
  webversecli tracks unlike sqli-mastery           # unlike a track

  webversecli vpn status
  webversecli vpn download [~/wv.ovpn]
""")

    sub = p.add_subparsers(dest="cmd", metavar="{config,me,labs,challenges,events,mystery,ranges,tracks,flag,learning-paths,leaderboard,vpn}")

    # ── config ────────────────────────────────────────────────────────────────
    cfg = sub.add_parser("config", help="Auth and configuration")
    cfg_sub = cfg.add_subparsers(dest="cfg_action")

    login_p = cfg_sub.add_parser("login", help="Login with email + password")
    login_p.add_argument("--email", default="")
    login_p.add_argument("--password", default="")

    cfg_sub.add_parser("logout", help="Logout and clear token")

    st = cfg_sub.add_parser("set-token", help="Set JWT token directly")
    st.add_argument("token")

    cfg_sub.add_parser("show", help="Show current token")

    # ── me ────────────────────────────────────────────────────────────────────
    me = sub.add_parser("me", help="User profile and stats")
    me_sub = me.add_subparsers(dest="me_action")
