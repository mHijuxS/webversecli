        info(f"User    : {d.get('username')}  (ID {d.get('id')})")
        info(f"Email   : {d.get('email')}")
        info(f"Pro     : {d.get('pro_status')}  |  All-access: {d.get('is_all_access')}")
        info(f"VPN IP  : {d.get('vpn_ip')}  |  Connected: {d.get('vpn_connected')}")
        info(f"Streak  : {d.get('solve_streak')} current  (best: {d.get('best_streak')})")
    elif action == "stats":
        d = _get("/api/user/stats")
        info(f"Rank    : {d.get('rank')}  →  {d.get('next_rank')}  ({d.get('xp')}/{d.get('next_rank_xp')} XP)")
        print()
        info(f"Labs    : {d.get('labs_solved')}/{d.get('labs_total')}  {_bar(d.get('labs_solved',0), d.get('labs_total',1))}")
        info(f"Chals   : {d.get('challenges_solved')}/{d.get('challenges_total')}  {_bar(d.get('challenges_solved',0), d.get('challenges_total',1))}")
        print()
        info(f"First bloods : {d.get('first_bloods_count')}  (labs: {d.get('lab_first_bloods')}, chals: {d.get('challenge_first_bloods')})")
        info(f"Streak : {d.get('solve_streak')} current  (best: {d.get('best_streak')}, freezes left: {d.get('streak_freezes_remaining')})")
        info(f"Avg solve time: {int(d.get('avg_solve_time', 0) / 60)} min")
        db = d.get("difficulty_breakdown", {})
        if db:
            print()
            rows = []
            for diff, v in db.items():
                rows.append([diff, str(v.get("solved", 0)), str(v.get("total", 0)), str(v.get("xp", 0))])
            table(["Difficulty", "Solved", "Total", "XP"], rows)
    elif action == "progress":
        d = _get("/api/user/progress")
        info(f"Rank: {d.get('rank')}  XP: {d.get('xp')}/{d.get('next_rank_xp')}  {_bar(d.get('xp',0) - d.get('rank_floor_xp',0), d.get('next_rank_xp',1) - d.get('rank_floor_xp',0))}")
        info(f"Labs completed: {d.get('completed_count')}/{d.get('total_labs')}")
        slugs = d.get("completed_slugs", [])
        if slugs:
            for i in range(0, len(slugs), 5):
                print("  " + "  ".join(slugs[i:i+5]))
        chal_slugs = d.get("completed_challenge_slugs", [])
        if chal_slugs:
            info(f"Challenges completed: {len(chal_slugs)}")
            for i in range(0, len(chal_slugs), 5):
                print("  " + "  ".join(chal_slugs[i:i+5]))
    elif action == "achievements":
        d = _get("/api/user/achievements")
        achs = d.get("achievements", [])
        unlocked = [a for a in achs if a.get("unlocked")]
        locked   = [a for a in achs if not a.get("unlocked") and not a.get("is_hidden")]
        info(f"Achievements: {len(unlocked)}/{len(achs)} unlocked")
        print()
        if unlocked:
            info("Unlocked:")
            rows = [[a["id"], a["name"], a.get("rarity",""), a.get("description","")[:60],
                     _fmt_time(a.get("unlocked_at",""))] for a in unlocked]
            table(["ID", "Name", "Rarity", "Description", "Unlocked At"], rows)
        if locked:
            print()
            info("Locked (visible):")
            rows = [[a["id"], a["name"], a.get("rarity",""), a.get("description","")[:60]] for a in locked]
            table(["ID", "Name", "Rarity", "Description"], rows)

