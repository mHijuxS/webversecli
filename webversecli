    # ── labs ──────────────────────────────────────────────────────────────────
    labs = sub.add_parser("labs", help="Lab management")
    labs_sub = labs.add_subparsers(dest="labs_action")

    ll = labs_sub.add_parser("list", help="List labs with optional filters")
