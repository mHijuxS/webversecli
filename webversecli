def cmd_tracks_list(args):
    data = _get("/api/tracks")

    # Apply family/difficulty/search from list metadata first
    filtered = []
    for t in data:
        if args.family and t.get("family", "").lower() != args.family.lower():
            continue
        if args.difficulty and t.get("difficulty", "").lower() != args.difficulty.lower():
            continue
        if args.search and not (_match(t.get("name", ""), args.search) or
                                _match(t.get("description", ""), args.search) or
                                _match(t.get("family", ""), args.search)):
            continue
        filtered.append(t)

    # --enrolled requires live state from detail endpoint (list doesn't carry it)
    if args.enrolled:
        import concurrent.futures as _cf
        def _fetch_state(t):
            try:
                d = _get(f"/api/tracks/{t['slug']}")
                t["enrolled"] = bool(d.get("enrolled"))
                t["liked"]    = bool(d.get("liked"))
                t["completed"]      = bool(d.get("completed"))
                t["completion_pct"] = d.get("completion_pct", 0)
            except SystemExit:
                pass
            return t
        with _cf.ThreadPoolExecutor(max_workers=8) as _ex:
            filtered = list(_ex.map(_fetch_state, filtered))
        filtered = [t for t in filtered if t.get("enrolled")]

    rows = []
    for t in filtered:
        enrolled_badge = _c("32", "enrolled") if t.get("enrolled") else _c("90", "-")
        liked_badge    = _c("33", "♥") if t.get("liked") else " "
        done_badge     = _c("32", "done") if t.get("completed") else _c("90", f"{t.get('completion_pct',0)}%")
        rows.append([
            t["slug"],
            t["name"],
            t.get("difficulty", ""),
            t.get("family", ""),
            str(t.get("item_count", "")),
            str(t.get("like_count", "")),
            enrolled_badge,
            liked_badge,
            done_badge,
        ])
    if not rows:
        info("No tracks match the given filters.")
        return
    table(["Slug", "Name", "Difficulty", "Family", "Items", "Likes", "Enrolled", "♥", "Progress"], rows)
    info(f"{len(rows)} track(s) shown.")

